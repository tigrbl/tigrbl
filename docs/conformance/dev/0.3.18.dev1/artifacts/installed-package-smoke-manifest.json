{
  "doctor_title": "Phase 12 Installed App",
  "doctor_version": "12.0.0",
  "install_mode": "isolated target install root",
  "installed_cli": {
    "app_title": "Phase 12 Installed App",
    "commands": [
      "run",
      "serve",
      "dev",
      "routes",
      "openapi",
      "openrpc",
      "doctor",
      "capabilities"
    ],
    "flags": [
      "--server",
      "--host",
      "--port",
      "--reload",
      "--workers",
      "--root-path",
      "--proxy-headers",
      "--uds",
      "--docs-path",
      "--openapi-path",
      "--openrpc-path",
      "--lens-path",
      "--statsd-addr",
      "--dogstatsd-tags",
      "--otel-endpoint",
      "--trace-sample-rate",
      "--drain-timeout",
      "--shutdown-timeout",
      "--concurrency-limit",
      "--admission-queue",
      "--backlog",
      "--ws-heartbeat",
      "--ws-heartbeat-timeout",
      "--http2-max-concurrent-streams",
      "--http2-initial-window-size",
      "--http3-max-data",
      "--http3-max-uni-streams",
      "--alpn-policy",
      "--ocsp-policy",
      "--revocation-policy",
      "--interop-bundle-dir",
      "--benchmark-bundle-dir",
      "--deployment-profile",
      "--proxy-contract",
      "--early-data-policy",
      "--origin-static-policy",
      "--quic-metrics",
      "--qlog-dir"
    ],
    "servers": {
      "gunicorn": true,
      "hypercorn": true,
      "tigrcorn": true,
      "uvicorn": true
    }
  },
  "openapi_version": "3.1.0",
  "openrpc_version": "1.2.6",
  "package_dir": "pkgs\\core\\tigrbl",
  "routes_contains": {
    "/docs": true,
    "/lens": true,
    "/openapi.json": true,
    "/openrpc.json": true,
    "/ping": true,
    "/ws/echo": true
  },
  "rust_binding_support": "deprecated; Tigrbl runtime execution is Python-only",
  "sdist": "tigrbl-0.4.1.tar.gz",
  "sdist_contents": {
    "contains_cli": true,
    "contains_pyproject": true,
    "contains_readme": true
  },
  "server_translation": {
    "gunicorn": {
      "bind": "0.0.0.0:9001",
      "forwarded_allow_ips": "*",
      "worker_class": "uvicorn.workers.UvicornWorker",
      "workers": 2
    },
    "hypercorn": {
      "bind": [
        "0.0.0.0:9001"
      ],
      "proxy_mode": "legacy",
      "root_path": "/root",
      "workers": 2
    },
    "tigrcorn": {
      "host": "0.0.0.0",
      "port": 9001,
      "proxy_headers": true,
      "root_path": "/root",
      "workers": 2
    },
    "uvicorn": {
      "host": "0.0.0.0",
      "port": 9001,
      "proxy_headers": true,
      "root_path": "/root"
    }
  },
  "wheel": "tigrbl-0.4.1-py3-none-any.whl",
  "wheel_entry_points": {
    "tigrbl": "tigrbl.cli:console_main"
  }
}
